{
  "name": "home-assistant-widget",
  "version": "3.6.0",
  "main": "main.js",
  "scripts": {
    "build:renderer": "vite build --mode production",
    "build:renderer:dev": "vite build --mode development",
    "start": "npm run build:renderer && node scripts/start-electron.cjs",
    "watch:renderer": "vite build --mode development --watch",
    "dev:once": "npm run build:renderer:dev && node scripts/start-electron.cjs --dev",
    "dev": "npm run build:renderer:dev && concurrently -k -n RENDERER,ELECTRON -c cyan,green \"npm:watch:renderer\" \"node scripts/start-electron.cjs --dev\"",
    "dist": "npm run build:renderer && electron-builder --win nsis portable",
    "dist:win": "npm run build:renderer && electron-builder --win nsis",
    "dist:mac": "npm run build:renderer && electron-builder --mac dmg zip --universal",
    "dist:linux": "npm run build:renderer && electron-builder --linux AppImage deb",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "home-assistant",
    "widget",
    "desktop",
    "dashboard",
    "smart-home",
    "automation",
    "electron",
    "rainmeter",
    "iot",
    "home-automation"
  ],
  "author": "Robertg761",
  "license": "MIT",
  "description": "Modern desktop widget for Home Assistant with real-time updates and drag-and-drop customization",
  "repository": {
    "type": "git",
    "url": "https://github.com/Robertg761/HA-Desktop-Widget.git"
  },
  "homepage": "https://github.com/Robertg761/HA-Desktop-Widget",
  "bugs": {
    "url": "https://github.com/Robertg761/HA-Desktop-Widget/issues"
  },
  "build": {
    "productName": "HA Desktop Widget",
    "appId": "com.github.robertg761.hadesktopwidget",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "afterPack": "scripts/after-pack-mac-adhoc-sign.cjs",
    "files": [
      "index.html",
      "locales/**/*",
      "main.js",
      "profile-sync-core.js",
      "preload.js",
      "src/**/*",
      "dist-renderer/**/*",
      "styles.css",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "asar": true,
    "compression": "normal",
    "publish": [
      {
        "provider": "github",
        "owner": "Robertg761",
        "repo": "HA-Desktop-Widget",
        "releaseType": "release"
      }
    ],
    "mac": {
      "minimumSystemVersion": "12.0",
      "x64ArchFiles": "**/uiohook-napi/prebuilds/darwin-*/uiohook-napi.node"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-Setup.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Home Assistant Widget"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-Portable.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "Robertg761",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@eslint/js": "^9.13.0",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.2.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.6",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.9.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.3.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "events": "^3.3.0",
    "hls.js": "^1.4.12",
    "sortablejs": "^1.15.6"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  }
}
